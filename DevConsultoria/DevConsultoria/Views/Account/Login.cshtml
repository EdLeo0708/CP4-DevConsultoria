@model DevConsultoria.Models.LoginViewModel
@{
    ViewData["Title"] = "Login Tech Líder";
}

@section Styles {
    <style>
        .login-wrapper {
            min-height: calc(100vh - 140px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 16px;
            background: radial-gradient(ellipse at 50% 50%, rgba(0,212,255,0.05) 0%, transparent 70%);
        }

        .login-card {
            background: #111827;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 24px;
            padding: 44px 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 40px 80px rgba(0,0,0,0.4);
        }

        .login-icon {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(13,110,253,0.15));
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: #00d4ff;
            margin: 0 auto 24px;
        }

        .login-title {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 1.6rem;
            color: #fff;
            text-align: center;
            margin-bottom: 6px;
        }

        .form-control {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: #e2e8f0;
            border-radius: 12px;
            padding: 12px 16px;
        }

            .form-control:focus {
                background: rgba(255,255,255,0.08);
                border-color: #00d4ff;
                color: #fff;
                box-shadow: 0 0 0 3px rgba(0,212,255,0.15);
            }

        .form-label {
            color: #94a3b8;
            font-size: .88rem;
            font-weight: 500;
        }

        .btn-login {
            background: linear-gradient(135deg, #00d4ff, #0d6efd);
            border: none;
            color: #fff;
            font-weight: 700;
            padding: 13px;
            border-radius: 12px;
            width: 100%;
            font-size: .95rem;
            transition: all .2s;
            margin-top: 8px;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 24px rgba(0,212,255,0.25);
                color: #fff;
            }

        .hint-box {
            background: rgba(13,110,253,0.08);
            border: 1px solid rgba(13,110,253,0.2);
            border-radius: 10px;
            padding: 12px 16px;
            font-size: .8rem;
            color: #64748b;
            margin-top: 20px;
            text-align: center;
        }
    </style>
}

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-icon"><i class="bi bi-person-lock"></i></div>
        <h1 class="login-title">Área Restrita</h1>
        <p class="text-secondary text-center small mb-4">Acesso exclusivo para Tech Líderes</p>

        @if (TempData["Erro"] != null)
        {
            <div class="alert alert-danger border-0 rounded-3 mb-3" style="background:rgba(220,38,38,0.1);color:#fca5a5;font-size:.88rem">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Erro"]
            </div>
        }

        <form asp-action="Login" method="post">
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <div class="mb-3">
                <label class="form-label">Usuário</label>
                <input asp-for="Usuario" class="form-control" placeholder="admin" autocomplete="username" />
            </div>
            <div class="mb-3">
                <label class="form-label">Senha</label>
                <input asp-for="Senha" type="password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
            </div>
            <button type="submit" class="btn btn-login">
                <i class="bi bi-unlock me-2"></i>Entrar no Dashboard
            </button>
        </form>

        <div class="hint-box">
            <i class="bi bi-info-circle me-1"></i>
            Demo: <strong class="text-info">admin</strong> / <strong class="text-info">admin123</strong>
        </div>
    </div>
</div>