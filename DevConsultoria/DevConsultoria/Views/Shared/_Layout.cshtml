<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DevConsultoria</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet" />

    <style>
        :root {
            --primary: #0d6efd;
            --dark: #0a0e1a;
            --card-bg: #111827;
            --border: rgba(255,255,255,0.08);
            --accent: #00d4ff;
        }
        body {
            font-family: 'Space Grotesk', sans-serif;
            background: var(--dark);
            color: #e2e8f0;
            min-height: 100vh;
        }
        .navbar-brand span {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 1.4rem;
            background: linear-gradient(135deg, #00d4ff, #0d6efd);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .navbar {
            background: rgba(10, 14, 26, 0.95) !important;
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(12px);
        }
        .nav-link {
            color: #94a3b8 !important;
            font-weight: 500;
            transition: color .2s;
        }
        .nav-link:hover, .nav-link.active { color: #fff !important; }
        .badge-online {
            width: 8px; height: 8px;
            background: #22c55e;
            border-radius: 50%;
            display: inline-block;
            margin-right: 6px;
            animation: pulse 2s infinite;
        }
        @@keyframes pulse {
            0%, 100% { opacity: 1; } 50% { opacity: .4; }
        }
        footer {
            background: rgba(0,0,0,0.3);
            border-top: 1px solid var(--border);
            padding: 2rem 0;
            margin-top: 4rem;
            color: #64748b;
            font-size: .85rem;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <i class="bi bi-braces-asterisk text-info fs-5"></i>
                <span>DevConsultoria</span>
            </a>
            <button class="navbar-toggler border-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <i class="bi bi-list text-white fs-4"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid-3x3-gap me-1"></i>Serviços
                        </a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("TechLider"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>
                    }
                </ul>
                <div class="d-flex align-items-center gap-3">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="text-sm text-info d-flex align-items-center">
                            <span class="badge-online"></span>
                            @User.Identity.Name
                            <span class="badge bg-warning text-dark ms-2 rounded-pill">Tech Líder</span>
                        </span>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-box-arrow-right me-1"></i>Sair
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-info btn-sm">
                            <i class="bi bi-person-lock me-1"></i>Admin
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer>
        <div class="container text-center">
            <p class="mb-1">
                <i class="bi bi-braces-asterisk text-info me-2"></i>
                <strong class="text-white">DevConsultoria</strong> &mdash; Soluções em Desenvolvimento de Software
            </p>
            <p class="mb-0">&copy; @DateTime.Now.Year &mdash; Todos os direitos reservados</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>